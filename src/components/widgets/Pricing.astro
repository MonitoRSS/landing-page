---
import { Icon } from 'astro-icon/components';
import Button from '~/components/ui/Button.astro';
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import type { Pricing } from '~/types';

const {
  title = '',
  subtitle = '',
  tagline = '',
  prices = [],

  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props as Pricing;

// The capacity sizer lives inside the Team card as a collapsible disclosure
// ("Size your plan"), so it reads as part of Team rather than an orphaned band,
// while staying collapsed by default to keep capacity demoted under the
// collaboration pitch. It renders for the plan that declares capacityScale (the
// Team tier); the live price is filled in by the inline script from precomputed
// Paddle previews.
---

<style>
  input:checked ~ .dot {
    transform: translateX(100%);
  }

  input:checked ~ .monthly-yearly-bg {
    background: rgb(34 197 94);
  }

  /* Rotate the disclosure chevron when the sizer is open. */
  .capacity-disclosure[open] .capacity-chevron {
    transform: rotate(180deg);
  }

  .capacity-disclosure summary::-webkit-details-marker {
    display: none;
  }
</style>
<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-7xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />
  <label for="termToggle" class="flex items-center cursor-pointer gap-x-2 justify-center">
    <div>Monthly</div>
    <!-- toggle -->
    <div class="relative">
      <!-- input -->
      <input type="checkbox" id="termToggle" class="sr-only" />
      <!-- line -->
      <div class="monthly-yearly-bg block bg-emphasized w-14 h-8 rounded-full transition"></div>
      <!-- dot -->
      <div class="dot absolute left-1 top-1 bg-white w-6 h-6 rounded-full transition"></div>
    </div>
    <!-- label -->
    <div class="flex items-center gap-2">
      Yearly
      <!-- <span class="inline-flex items-center rounded-lg bg-green-50 px-2 py-1 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20">Save 15%!</span> -->
    </div>
  </label>
  <div class="flex justify-center text-sm text-success mt-2 mb-16">
    <span
      class="inline-flex items-center rounded-md bg-emphasized px-2 py-1 text-sm font-medium text-success ring-1 ring-inset ring-success"
      >Save 15% with a yearly plan!</span
    >
  </div>
  <div class="flex items-stretch justify-center">
    <div
      class="flex flex-wrap sm:grid grid-cols-3 gap-4 dark:text-default sm:grid-cols-2 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-3"
    >
      {
        prices &&
          prices.map(
            ({
              id,
              title,
              subtitle,
              priceMonthly,
              priceYearly,
              pricePrefix,
              priceNote,
              items,
              callToAction,
              capacityScale,
              hasRibbon = false,
              ribbonTitle,
              isHighlighted = false,
            }) => (
              <div class="col-span-3 mx-auto flex w-full justify-center sm:col-span-1 sm:justify-stretch md:col-span-1 lg:col-span-1 xl:col-span-1">
                {priceMonthly && priceYearly && (
                  <div
                    class={`rounded-lg backdrop-blur border bg-white dark:bg-panel shadow px-6 py-8 flex w-full max-w-sm flex-col justify-between text-center ${isHighlighted ? 'border-2 border-primary' : 'border-gray-200 dark:border-border-default'}`}
                  >
                    {hasRibbon && ribbonTitle && (
                      <div class="absolute right-[-5px] 2xl:right-[-8px] rtl:right-auto rtl:left-[-8px] rtl:2xl:left-[-10px] top-[-5px] 2xl:top-[-10px] z-[1] h-[100px] w-[100px] overflow-hidden text-right">
                        <span class="absolute top-[19px] right-[-21px] rtl:right-auto rtl:left-[-21px] block w-full rotate-45 rtl:-rotate-45 bg-success text-center text-[10px] font-bold uppercase leading-5 text-page shadow-[0_3px_10px_-5px_rgba(0,0,0,0.3)] before:absolute before:left-0 before:top-full before:z-[-1] before:border-[3px] before:border-r-transparent before:border-b-transparent before:border-l-success before:border-t-success before:content-[''] after:absolute after:right-0 after:top-full after:z-[-1] after:border-[3px] after:border-l-transparent after:border-b-transparent after:border-r-success after:border-t-success after:content-['']">
                          {ribbonTitle}
                        </span>
                      </div>
                    )}
                    <div class="px-2 py-0">
                      {title && (
                        <h3 class="text-center text-xl font-semibold uppercase leading-6 tracking-wider mb-2">
                          {title}
                        </h3>
                      )}
                      {subtitle && (
                        <p class="font-light sm:text-base text-gray-600 dark:text-muted min-h-[3rem]">{subtitle}</p>
                      )}
                      <div class="my-8 monthly-price">
                        {pricePrefix && (
                          <span class="block text-base lowercase text-center text-gray-600 dark:text-muted">
                            {pricePrefix}
                          </span>
                        )}
                        <div class="flex items-center justify-center text-center mb-1">
                          <div role="status" class="loading-price">
                            <svg
                              aria-hidden="true"
                              class="w-8 h-8 mr-2 text-gray-200 animate-spin dark:text-subtle fill-primary"
                              viewBox="0 0 100 101"
                              fill="none"
                              xmlns="http://www.w3.org/2000/svg"
                            >
                              <path
                                d="M100 50.5908C100 78.2051 77.6142 100.591 50 100.591C22.3858 100.591 0 78.2051 0 50.5908C0 22.9766 22.3858 0.59082 50 0.59082C77.6142 0.59082 100 22.9766 100 50.5908ZM9.08144 50.5908C9.08144 73.1895 27.4013 91.5094 50 91.5094C72.5987 91.5094 90.9186 73.1895 90.9186 50.5908C90.9186 27.9921 72.5987 9.67226 50 9.67226C27.4013 9.67226 9.08144 27.9921 9.08144 50.5908Z"
                                fill="currentColor"
                              />
                              <path
                                d="M93.9676 39.0409C96.393 38.4038 97.8624 35.9116 97.0079 33.5539C95.2932 28.8227 92.871 24.3692 89.8167 20.348C85.8452 15.1192 80.8826 10.7238 75.2124 7.41289C69.5422 4.10194 63.2754 1.94025 56.7698 1.05124C51.7666 0.367541 46.6976 0.446843 41.7345 1.27873C39.2613 1.69328 37.813 4.19778 38.4501 6.62326C39.0873 9.04874 41.5694 10.4717 44.0505 10.1071C47.8511 9.54855 51.7191 9.52689 55.5402 10.0491C60.8642 10.7766 65.9928 12.5457 70.6331 15.2552C75.2735 17.9648 79.3347 21.5619 82.5849 25.841C84.9175 28.9121 86.7997 32.2913 88.1811 35.8758C89.083 38.2158 91.5421 39.6781 93.9676 39.0409Z"
                                fill="currentFill"
                              />
                            </svg>
                            <span class="sr-only">loading...</span>
                          </div>
                          <span
                            id={`price-monthly-number-${id}`}
                            class={`text-6xl font-extrabold price-number hidden`}
                            data-free-amount={priceMonthly === 0 || priceMonthly === '0' ? '0' : undefined}
                          >
                            ${priceMonthly}
                          </span>
                        </div>
                        <span class="text-base leading-6 lowercase text-gray-600 dark:text-muted price-term">
                          Per Month
                        </span>
                        {priceNote && <p class="mt-2 text-sm text-gray-600 dark:text-muted">{priceNote}</p>}
                      </div>
                      {items && (
                        <ul role="list" class="my-8 md:my-10 space-y-2 text-left">
                          {items.map(
                            ({ description, icon, unavailable, partlyAvailable }) =>
                              description && (
                                <li class="mb-1.5 flex items-start space-x-3 leading-7">
                                  {!unavailable && !partlyAvailable && (
                                    <div class="rounded-full bg-primary mt-1">
                                      <Icon
                                        name={icon ? icon : 'tabler:check'}
                                        class="w-5 h-5 font-bold p-1 text-white"
                                      />
                                    </div>
                                  )}
                                  {unavailable && (
                                    <div class="rounded-full bg-emphasized mt-1 w-min">
                                      <Icon name={'tabler:x'} class="w-5 h-5 font-bold p-1 text-muted" />
                                    </div>
                                  )}
                                  {partlyAvailable && (
                                    <div class="rounded-full bg-warning mt-1 w-min">
                                      <Icon name={'tabler:exclamation-mark'} class="w-5 h-5 font-bold p-1 text-page" />
                                    </div>
                                  )}
                                  <span>{description}</span>
                                </li>
                              )
                          )}
                        </ul>
                      )}
                      {capacityScale && capacityScale.length > 0 && (
                        <details
                          class="capacity-disclosure mb-6 rounded-lg border border-gray-200 bg-gray-50 text-left dark:border-border-default dark:bg-emphasized"
                          data-capacity-card={id}
                          data-detents={JSON.stringify(capacityScale)}
                        >
                          <summary class="flex cursor-pointer list-none items-center justify-between gap-2 px-4 py-3 text-sm font-medium">
                            <span>
                              Size your plan &middot;{' '}
                              <span class="capacity-summary-price text-link">from &hellip;</span>
                            </span>
                            <svg
                              class="capacity-chevron h-4 w-4 text-muted transition-transform"
                              viewBox="0 0 20 20"
                              fill="currentColor"
                              aria-hidden="true"
                            >
                              <path
                                fill-rule="evenodd"
                                d="M5.23 7.21a.75.75 0 011.06.02L10 11.17l3.71-3.94a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                                clip-rule="evenodd"
                              />
                            </svg>
                          </summary>
                          <div class="border-t border-gray-200 px-4 pb-4 pt-3 dark:border-border-default">
                            <label for={`capacity-slider-${id}`} class="block text-sm text-gray-600 dark:text-muted">
                              <span class="capacity-feeds font-semibold text-link">{capacityScale[0]}</span> feeds for{' '}
                              <span class="capacity-price font-semibold text-link">&hellip;</span>{' '}
                              <span class="capacity-term lowercase">per month</span>
                            </label>
                            <input
                              type="range"
                              id={`capacity-slider-${id}`}
                              class="capacity-slider mt-3 w-full accent-primary"
                              min="0"
                              max={capacityScale.length - 1}
                              step="1"
                              value="0"
                              aria-label="Team feed capacity"
                            />
                            <div class="mt-2 flex justify-between text-xs text-gray-600 dark:text-muted">
                              {capacityScale.map((count, i) => (
                                <span>
                                  {count}
                                  {i === capacityScale.length - 1 ? '+' : ''}
                                </span>
                              ))}
                            </div>
                            <p class="mt-3 text-xs text-gray-600 dark:text-muted">
                              Set your capacity when you create the workspace. Works solo, invite people later.
                            </p>
                          </div>
                        </details>
                      )}
                    </div>
                    {callToAction && (
                      <div class={`flex justify-center`}>
                        {typeof callToAction === 'string' ? (
                          <Fragment set:html={callToAction} />
                        ) : (
                          callToAction &&
                          callToAction.href && (
                            <Button
                              {...(hasRibbon ? { variant: 'primary' } : {})}
                              {...callToAction}
                              id={`price-cta-${id}`}
                              target="_blank"
                            />
                          )
                        )}
                      </div>
                    )}
                  </div>
                )}
              </div>
            )
          )
      }
    </div>
  </div>

  <div class="text-center text-muted mt-4 text-xs">
    * Rich content from article pages pulls extra images, links, or thumbnails from each linked article's own
    webpage. Available on feeds with fewer than 51 articles.
  </div>

  <div class="text-center text-muted mt-4">
    The checkout process is handled by our reseller and Merchant of Record, Paddle.com, who also handles
    subscription-related inquiries.
  </div>
</WidgetWrapper>
<script is:inline src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>

<script is:inline>
  var PRODUCT_NAMES = {
    tier1: 'Personal',
    tier2: 'Team',
  };

  // tier1 = Personal base price; tier2 = Team base price (the 70-feed workspace).
  // The Team card shows the tier2 base as its "from" anchor; the live capacity
  // slider (and the per-feed overage pricing) lives in the app.
  var monthlyPriceIds = ['pri_01hb3f68thdjksrra9c9aky680', 'pri_01hbnmmra6kxk0k8c8arkqv6xf'];
  var yearlyPriceIds = ['pri_01hbnmkcspvd0nqaw5jecxagna', 'pri_01hbnmnb33yp8symhtn9zdvgh3'];

  // The live Team capacity slider prices each detent as the Team base (tier2)
  // plus a per-feed add-on for the overage above the base detent, the same
  // basket the in-app slider buys. These are the production Paddle price ids by
  // interval. The detent feed counts come from the rendered slider's
  // data-detents attribute (single source of truth with capacityScale), and the
  // base feed count is detents[0] — nothing about the ladder is hardcoded here.
  var TEAM_BASE_PRICE_IDS = { month: 'pri_01hbnmmra6kxk0k8c8arkqv6xf', year: 'pri_01hbnmnb33yp8symhtn9zdvgh3' };
  var TEAM_FEED_ADDON_PRICE_IDS = { month: 'pri_01jzdyaa7sr427yre37j0m1h74', year: 'pri_01jzdybc83226zq2ea8cs0csd5' };
  // Precomputed formatted prices per detent index, keyed by interval. Filled once
  // per term so dragging the snap-to-detents slider is instant with no per-drag call.
  var teamDetentPrices = { month: [], year: [] };

  var cachedResponses = {};

  // eslint-disable-next-line no-undef
  Paddle.Setup({
    token: 'live_fb886090792caaa1fd734939496',
  });

  var getCurrentTextClass = (elem) => {
    var currentTextClass = Array.from(elem.classList ?? []).find((c) => c.startsWith('text-'));

    return currentTextClass;
  };

  function setPriceDisplays(productsOfCurrency) {
    if (!productsOfCurrency?.length) {
      return;
    }

    var maxYearlyCharLength = Math.max(
      ...productsOfCurrency
        .flatMap((p) => p.prices.filter((p) => p.interval === 'year'))
        .map((p) => p.formattedPrice.length)
    );

    var getTextSizeFromLength = () => {
      if (maxYearlyCharLength < 9) {
        return 'text-6xl';
      } else if (maxYearlyCharLength < 10) {
        return 'text-5xl';
      } else {
        return 'text-4xl';
      }
    };

    var idealFontSize = getTextSizeFromLength();

    productsOfCurrency.forEach((product) => {
      var monthlyPrice = product?.prices.find((p) => p.interval === 'month')?.formattedPrice;
      var yearlyPrice = product?.prices.find((p) => p.interval === 'year')?.formattedPrice;
      var monthlyElem = document.querySelector(`#price-monthly-number-${product.id}`);
      var allPriceElems = document.querySelectorAll(`.price-number`);

      allPriceElems.forEach((elem) => {
        var currentTextClass = getCurrentTextClass(elem);

        if (currentTextClass) {
          elem.classList.remove(currentTextClass);
        }

        elem.classList.add(idealFontSize);
      });

      if (monthlyElem) {
        if (monthlyPrice) {
          monthlyElem.innerHTML = monthlyPrice;
        } else if (yearlyPrice) {
          monthlyElem.innerHTML = yearlyPrice;
        }
      }
    });
  }

  async function fetchPrices(term) {
    if (!monthlyPriceIds.length || !yearlyPriceIds.length) {
      throw new Error('No monthly or yearly prices available');
    }

    if (cachedResponses[term]) {
      return cachedResponses[term];
    }

    var priceIds = term === 'monthly' ? monthlyPriceIds : yearlyPriceIds;

    // eslint-disable-next-line no-undef
    var previewData = await Paddle.PricePreview({
      items: priceIds.map((id) => ({
        priceId: id,
        quantity: 1,
      })),
    });

    var pricesByProduct = {};

    var { details, currencyCode } = previewData.data;

    // var previewData.data.currencyCode
    for (let i = 0; i < details.lineItems.length; i += 1) {
      var {
        totals,
        product,
        price: { billingCycle, id: priceId },
      } = previewData.data.details.lineItems[i];
      var useProductId = product.customData?.key;

      if (!billingCycle || !useProductId) {
        continue;
      }

      var formattedPrice = {
        id: priceId,
        interval: billingCycle.interval,
        // Format from the minor-unit total via the shared helper so card prices
        // and the Team capacity slider use one identical currency format.
        formattedPrice: formatMinorUnitTotal(parseInt(totals.total, 10), currencyCode),
        currencyCode,
      };

      var prices = pricesByProduct[useProductId]?.prices;

      if (!prices) {
        pricesByProduct[useProductId] = {
          id: useProductId,
          name: PRODUCT_NAMES[useProductId],
          prices: [formattedPrice],
        };
      } else {
        prices.push(formattedPrice);
      }
    }

    var toReturn = {
      products: pricesByProduct,
      currencyCode,
    };

    cachedResponses[term] = toReturn;

    return toReturn;
  }

  async function fetchAndSetDisplayPrices(term) {
    document.querySelectorAll('.loading-price').forEach((elem) => {
      elem.classList.remove('hidden');
    });

    document.querySelectorAll('.price-number').forEach((elem) => {
      elem.classList.add('hidden');
    });

    var { products, currencyCode } = await fetchPrices(term);

    document.querySelectorAll('.loading-price').forEach((elem) => {
      elem.classList.add('hidden');
    });

    document.querySelectorAll('.price-number').forEach((elem) => {
      elem.classList.remove('hidden');
    });

    // Free cards aren't Paddle products, so they have no localized preview. Format
    // their amount (0) with the same currency Paddle detected for the paid tiers,
    // through the shared helper, so the symbol matches the rest of the page
    // instead of the hardcoded "$0".
    if (currencyCode) {
      document.querySelectorAll('.price-number[data-free-amount]').forEach((elem) => {
        var amount = parseInt(elem.dataset.freeAmount, 10) || 0;
        elem.innerHTML = formatMinorUnitTotal(amount, currencyCode);
      });
    }

    var productsArray = Object.values(products);

    setPriceDisplays(productsArray);

    productsArray.forEach(({ id, prices }) => {
      // A capacity-scaled card (it renders the in-app sizing slider) prices off
      // the workspace base, but the chosen capacity is set on the in-app slider,
      // so its CTA stays a plain link into the app rather than a single-price
      // checkout deep link. Detect that from the rendered slider rather than a
      // hardcoded product id so a tier rename can't silently re-enable the
      // deep link.
      if (document.querySelector(`.capacity-disclosure[data-capacity-card="${id}"]`)) {
        return;
      }

      var priceId = prices[0].id;

      var buttonElement = document.getElementById(`price-cta-${id}`);

      if (!buttonElement) {
        return;
      }

      buttonElement.href = `https://my.monitorss.xyz/settings?priceId=${priceId}`;
    });
  }

  function changeTerms(isYearly) {
    fetchAndSetDisplayPrices(isYearly ? 'yearly' : 'monthly');
    const termElems = document.querySelectorAll('.price-term');

    termElems.forEach((elem) => {
      if (isYearly) {
        elem.innerHTML = 'Per Year';
      } else {
        elem.innerHTML = 'Per Month';
      }
    });
  }

  // Format a minor-unit (e.g. cents) integer total as a localized currency
  // string, deriving the currency's fraction digits so zero-decimal currencies
  // (e.g. JPY) are handled. Drops a trailing ".00" to match the card prices.
  // The card prices flow through this same helper (see fetchPrices), so the
  // Team slider and the card "from" anchor can never format inconsistently.
  var currencyFormatters = {};

  function formatMinorUnitTotal(minorUnitTotal, currencyCode) {
    var formatter = currencyFormatters[currencyCode];

    if (!formatter) {
      formatter = new Intl.NumberFormat(undefined, {
        style: 'currency',
        currency: currencyCode,
      });
      currencyFormatters[currencyCode] = formatter;
    }

    var fractionDigits = formatter.resolvedOptions().maximumFractionDigits;
    var majorUnitTotal = minorUnitTotal / Math.pow(10, fractionDigits);
    var formatted = formatter.format(majorUnitTotal);

    return formatted.endsWith('.00') ? formatted.slice(0, -3) : formatted;
  }

  // Read the detent feed counts from the rendered slider's data-detents
  // attribute. This is the single source of truth (it mirrors capacityScale in
  // the page data), so the script never hardcodes the ladder or the base count.
  function getTeamDetents() {
    var disclosure = document.querySelector('.capacity-disclosure[data-detents]');

    if (!disclosure) {
      return [];
    }

    try {
      var detents = JSON.parse(disclosure.dataset.detents);

      return Array.isArray(detents) ? detents : [];
    } catch (err) {
      // eslint-disable-next-line no-console
      console.error('Invalid capacity detents', disclosure.dataset.detents, err);

      return [];
    }
  }

  // Preview every detent's price in a SINGLE Paddle.PricePreview call. We send
  // the base (qty 1) plus the add-on at the largest overage, then read each
  // line item's PER-UNIT minor-unit amount (unitTotals.total). Every detent's
  // total is base + overage*addonUnit, computed locally — no per-detent network
  // call, and the base line item is the same basket the card already previews.
  async function previewTeamDetentPrices(interval, detents) {
    var baseFeeds = detents[0];
    var maxOverage = Math.max(0, detents[detents.length - 1] - baseFeeds);

    var items = [{ priceId: TEAM_BASE_PRICE_IDS[interval], quantity: 1 }];

    if (maxOverage > 0) {
      items.push({ priceId: TEAM_FEED_ADDON_PRICE_IDS[interval], quantity: maxOverage });
    }

    // eslint-disable-next-line no-undef
    var previewData = await Paddle.PricePreview({ items: items });
    var currencyCode = previewData.data.currencyCode;
    var lineItems = previewData.data.details.lineItems;

    var baseUnit = parseInt(lineItems[0].unitTotals.total, 10);
    var addonUnit = lineItems[1] ? parseInt(lineItems[1].unitTotals.total, 10) : 0;

    return detents.map(function (feeds) {
      var overage = Math.max(0, feeds - baseFeeds);

      return formatMinorUnitTotal(baseUnit + overage * addonUnit, currencyCode);
    });
  }

  function renderTeamCapacity(index, interval) {
    var disclosure = document.querySelector('.capacity-disclosure');

    if (!disclosure) {
      return;
    }

    var feedsElem = disclosure.querySelector('.capacity-feeds');
    var priceElem = disclosure.querySelector('.capacity-price');
    var termElem = disclosure.querySelector('.capacity-term');

    if (!feedsElem || !priceElem || !termElem) {
      return;
    }

    var detents = getTeamDetents();
    var feeds = detents[index];

    feedsElem.textContent = index === detents.length - 1 ? feeds + '+' : String(feeds);
    termElem.textContent = interval === 'year' ? 'per year' : 'per month';

    var cached = teamDetentPrices[interval][index];
    priceElem.textContent = cached || '…';

    // The collapsed disclosure summary always shows the entry price ("from
    // $X"), i.e. the lowest detent, so the cost is visible without opening it.
    var summaryPriceElem = disclosure.querySelector('.capacity-summary-price');

    if (summaryPriceElem) {
      var lowest = teamDetentPrices[interval][0];
      summaryPriceElem.textContent = lowest ? 'from ' + lowest : 'from …';
    }
  }

  // Precompute the detent prices for the term once, then dragging is instant.
  // Re-run while any detent is still unpriced (length short, or a prior attempt
  // left blanks after a transient failure) so a single network blip doesn't
  // permanently poison a detent for the session.
  async function precomputeTeamDetentPrices(interval) {
    var detents = getTeamDetents();

    if (!detents.length) {
      return;
    }

    var current = teamDetentPrices[interval];

    if (current.length === detents.length && current.every(Boolean)) {
      return;
    }

    try {
      teamDetentPrices[interval] = await previewTeamDetentPrices(interval, detents);
    } catch (err) {
      // eslint-disable-next-line no-console
      console.error('Failed to preview Team capacity prices', interval, err);
    }
  }

  async function setupTeamCapacitySlider(interval) {
    var slider = document.querySelector('.capacity-slider');

    if (!slider) {
      return;
    }

    renderTeamCapacity(parseInt(slider.value, 10), interval);
    await precomputeTeamDetentPrices(interval);
    // Re-read the live term after the await: a rapid toggle may have changed it
    // while this interval's prices were loading, and rendering the captured
    // interval would repaint the disclosure with the wrong term's prices.
    var liveInterval = document.getElementById('termToggle')?.checked ? 'year' : 'month';
    renderTeamCapacity(parseInt(slider.value, 10), liveInterval);

    if (!slider.dataset.bound) {
      slider.dataset.bound = 'true';
      slider.addEventListener('input', function () {
        var currentInterval = document.getElementById('termToggle')?.checked ? 'year' : 'month';
        renderTeamCapacity(parseInt(this.value, 10), currentInterval);
      });
    }
  }

  window.addEventListener('load', function () {
    var termToggle = document.getElementById('termToggle');

    termToggle?.addEventListener('change', function () {
      var isYearly = this.checked;

      changeTerms(isYearly);
      setupTeamCapacitySlider(isYearly ? 'year' : 'month');
    });

    fetchAndSetDisplayPrices(termToggle?.checked ? 'yearly' : 'monthly');
    setupTeamCapacitySlider(termToggle?.checked ? 'year' : 'month');
  });
</script>
