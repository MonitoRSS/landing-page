---
import { getPermalink } from '~/utils/permalinks';

import { APP_BLOG } from '~/utils/config';
import type { Post } from '~/types';

export interface Props {
  tags: Post['tags'];
  class?: string;  
  title?: string | undefined;
  isCategory?: boolean;
}

const { tags, class: className = 'text-sm', title = undefined, isCategory = false } = Astro.props;
---

{
  tags && Array.isArray(tags) && (
    <>
      <>
        {title !== undefined && <span class="align-super font-normal underline underline-offset-4 decoration-2 text-muted">{title}</span>}
      </>
      <ul class={className}>
        {tags.map((tag) => (
          <li class="bg-emphasized inline-block mr-2 mb-2 py-0.5 px-2 lowercase font-medium">
            {!APP_BLOG?.tag?.isEnabled ? (
              tag
            ) : (
              <a
                href={getPermalink(tag, (isCategory ? 'category' : 'tag'))}
                class="text-muted hover:text-link"
              >
                {tag}
              </a>
            )}
          </li>
        ))}
      </ul>
    </>
  )
}
