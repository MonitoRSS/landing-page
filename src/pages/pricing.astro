---
import Layout from '~/layouts/PageLayout.astro';

import Pricing from '~/components/widgets/Pricing.astro';
import FAQs from '../components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import PricingTable from '../components/widgets/PricingTable.astro';

const metadata = {
  title: 'Pricing',
};

enum Price {
  Free = 'Free',
  Personal = 'Personal',
  Team = 'Team',
}
---

<Layout metadata={metadata}>
  <Pricing
    title="Pricing"
    subtitle="MonitoRSS is free to use and self-host, but you can show your support for the open-source development/hosting of MonitoRSS and get access to better features!"
    prices={[
      {
        id: 'free',
        title: Price.Free,
        priceMonthly: '0',
        priceYearly: '0',
        subtitle: 'Try it out, no strings attached.',
        items: [
          {
            description: 'Track up to 3 feeds',
            icon: 'tabler:check',
          },
          {
            description: '50 articles per day, per feed',
            icon: 'tabler:check',
          },
          {
            description: 'Feeds checked every 20 minutes',
            icon: 'tabler:check',
          },
          {
            description: 'Branded message delivery',
            unavailable: true,
          },
          {
            description: 'Custom placeholders',
            unavailable: true,
          },
        ],
        callToAction: {
          target: '_blank',
          text: 'Get Started',
          href: 'https://my.monitorss.xyz',
          class: 'hover:border-border-control',
        },
      },
      {
        id: 'tier1',
        title: Price.Personal,
        priceMonthly: '5',
        priceYearly: 51,
        subtitle: 'Track feeds on your own.',
        items: [
          {
            description: 'Track 35 feeds',
            icon: 'tabler:check',
          },
          {
            description: '1,000 articles per day, per feed',
            icon: 'tabler:check',
          },
          {
            description: 'Feeds checked every 2 minutes',
            icon: 'tabler:check',
          },
          {
            description: 'Branded message delivery',
            icon: 'tabler:check',
          },
          {
            description: 'Custom placeholders',
            icon: 'tabler:check',
          },
        ],
        callToAction: {
          target: '_blank',
          text: 'Choose Personal',
          // The runtime rewrites this to a .../settings?priceId=… checkout deep
          // link once Paddle prices load; this is only the no-JS fallback.
          href: 'https://my.monitorss.xyz',
          class: 'hover:border-border-control',
        },
        hasRibbon: true,
        ribbonTitle: 'popular',
      },
      {
        id: 'tier2',
        title: Price.Team,
        priceMonthly: 10,
        priceYearly: 102,
        pricePrefix: 'from',
        subtitle: 'Open a shared workspace your team manages together.',
        capacityScale: [70, 100, 140, 200, 300, 500],
        items: [
          {
            description: 'Everything in Personal',
            icon: 'tabler:check',
          },
          {
            description: 'Add unlimited teammates, free',
            icon: 'tabler:check',
          },
          {
            description: 'Rich content from article pages*',
            icon: 'tabler:check',
          },
        ],
        callToAction: {
          target: '_blank',
          text: 'Create a workspace',
          href: 'https://my.monitorss.xyz',
          class: 'hover:border-border-control',
        },
      },
    ]}
  />

